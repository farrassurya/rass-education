<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="@drawable/bg_gradient_orange">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivProfile"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="40dp"
                android:padding="2dp"
                android:scaleType="centerCrop"
                android:src="@drawable/rass"
                app:shapeAppearanceOverlay="@style/CircleImage"
                app:strokeColor="@color/white"
                app:strokeWidth="4dp" />

            <TextView
                android:id="@+id/tvWelcomeTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/ivProfile"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="16dp"
                android:text="Welcome Farrassurya!"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Search Bar -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Cari No. Sertifikat / Nama Pemilik"
                app:boxStrokeColor="@color/orange_primary"
                app:hintTextColor="@color/orange_primary"
                app:startIconDrawable="@android:drawable/ic_menu_search">

                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Aksi Cepat"
                android:textColor="#333333"
                android:textSize="18sp"
                android:textStyle="bold" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:alignmentMode="alignMargins"
                android:columnCount="2">

                <!--
                     UKURAN EKSTRA KOMPAK (40dp) & SEJAJAR 100%:
                     Semua pakai inset 0dp agar tinggi 40dp adalah murni ukuran tombol tanpa padding luar.
                -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRumus"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="Rumus Lahan"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    app:backgroundTint="@color/orange_primary"
                    app:cornerRadius="8dp"
                    app:icon="@drawable/ic_home"
                    app:iconSize="14dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFocus"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="Zona Pantau"
                    android:textAllCaps="false"
                    android:textColor="@color/orange_primary"
                    android:textSize="11sp"
                    app:cornerRadius="8dp"
                    app:icon="@drawable/ic_home"
                    app:iconSize="14dp"
                    app:iconTint="@color/orange_primary"
                    app:strokeColor="@color/orange_primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnInspirasi"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="Galeri Desa"
                    android:textAllCaps="false"
                    android:textColor="@color/orange_primary"
                    android:textSize="11sp"
                    app:cornerRadius="8dp"
                    app:icon="@drawable/ic_info"
                    app:iconSize="14dp"
                    app:iconTint="@color/orange_primary"
                    app:strokeColor="@color/orange_primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnWebView"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="Portal Web"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    app:backgroundTint="@color/orange_primary"
                    app:cornerRadius="8dp"
                    app:icon="@drawable/ic_info"
                    app:iconSize="14dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTabLayout"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="Tab Layout"
                    android:textAllCaps="false"
                    android:textColor="@color/orange_primary"
                    android:textSize="11sp"
                    app:cornerRadius="8dp"
                    app:icon="@drawable/ic_settings"
                    app:iconSize="14dp"
                    app:iconTint="@color/orange_primary"
                    app:strokeColor="@color/orange_primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnReminder"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="@string/home_reminder_button"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    app:backgroundTint="@color/orange_primary"
                    app:cornerRadius="8dp"
                    app:icon="@android:drawable/ic_lock_idle_alarm"
                    app:iconSize="14dp" />

            </GridLayout>

            <!-- Riwayat Aktivitas -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Aktivitas Terakhir"
                android:textColor="#333333"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvEmptyHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_card_white"
                android:elevation="2dp"
                android:padding="20dp"
                android:text="Belum ada aktivitas"
                android:textAlignment="center"
                android:textColor="#888888"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_card_white"
                android:elevation="2dp"
                android:padding="12dp"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_history" />

            <!-- Berita -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/p11_news_title"
                android:textColor="#333333"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvNewsStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/p11_news_loading"
                android:textColor="#666666"
                android:textSize="14sp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvNews"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_news" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="20dp"
                android:text="Keluar Aplikasi"
                android:textAllCaps="false"
                android:textColor="@color/white"
                app:backgroundTint="#E45B5B"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/ic_lock_power_off"
                app:iconTint="@color/white" />

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
