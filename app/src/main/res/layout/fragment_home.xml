<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- // MODIF: Header dengan Background Drawable Gradient -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="@drawable/bg_gradient_orange">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivProfile"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="40dp"
                android:padding="2dp"
                android:scaleType="centerCrop"
                android:src="@drawable/rass"
                app:shapeAppearanceOverlay="@style/CircleImage"
                app:strokeColor="@color/white"
                app:strokeWidth="4dp" />

            <TextView
                android:id="@+id/tvWelcomeTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/ivProfile"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="16dp"
                android:text="Welcome Farrassurya!"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- // MODIF: TextInputLayout Pencarian -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Cari No. Sertifikat / Nama Pemilik"
                app:boxStrokeColor="@color/orange_primary"
                app:hintTextColor="@color/orange_primary"
                app:startIconDrawable="@android:drawable/ic_menu_search">

                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Status Proyek Bina Desa"
                android:textColor="#333333"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- // REVISI: ChipGroup Aktif & Bisa Ditekan -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:selectionRequired="true"
                app:singleSelection="true">

                <!-- // REVISI: Logo Chip Aktif diganti ke ic_menu_edit (Bukan mic lagi) -->
                <com.google.android.material.chip.Chip
                    android:id="@+id/chipActive"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:checked="true"
                    android:text="Aktif"
                    app:chipIcon="@android:drawable/ic_menu_edit"
                    app:chipIconVisible="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipPending"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:text="Tertunda"
                    app:chipIcon="@android:drawable/ic_menu_recent_history"
                    app:chipIconVisible="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipFinished"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:text="Selesai"
                    app:chipIcon="@android:drawable/checkbox_on_background"
                    app:chipIconVisible="true" />
            </com.google.android.material.chip.ChipGroup>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Daftar Tugas Hari Ini"
                android:textColor="#333333"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- // MODIF: Cardview dengan Background Drawable -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_card_white"
                android:elevation="4dp"
                android:orientation="vertical"
                android:padding="15dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Prioritas Utama"
                    android:textColor="@color/orange_primary"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="- Verifikasi dokumen fisik di Balai Desa\n- Input data koordinat peta bidang"
                    android:textColor="#333333" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Aksi Cepat"
                android:textColor="#333333"
                android:textSize="18sp"
                android:textStyle="bold" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:alignmentMode="alignMargins"
                android:columnCount="2">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRumus"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="65dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="Rumus Lahan"
                    android:textColor="@color/white"
                    app:backgroundTint="@color/orange_primary"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/ic_home"
                    app:iconTint="@color/white" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFocus"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="65dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="Zona Pantau"
                    android:textColor="@color/orange_primary"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/ic_home"
                    app:iconTint="@color/orange_primary"
                    app:strokeColor="@color/orange_primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnInspirasi"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="65dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="Galeri Desa"
                    android:textColor="@color/orange_primary"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/ic_info"
                    app:iconTint="@color/orange_primary"
                    app:strokeColor="@color/orange_primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnWebView"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="65dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="Portal Web"
                    android:textColor="@color/white"
                    app:backgroundTint="@color/orange_primary"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/ic_info"
                    app:iconTint="@color/white" />

            </GridLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="20dp"
                android:text="Keluar Aplikasi"
                android:textAllCaps="false"
                android:textColor="@color/white"
                app:backgroundTint="#E45B5B"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/ic_lock_power_off"
                app:iconTint="@color/white" />

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>