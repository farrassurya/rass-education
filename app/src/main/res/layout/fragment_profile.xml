<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5"
    android:gravity="center_horizontal">

    <!-- // BARU: Layout Fragment Profile -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarProfile"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/orange_primary"
        app:title="Developer Profile"
        app:titleTextColor="@color/white" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivDevProfile"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:layout_marginTop="40dp"
        android:padding="4dp"
        android:scaleType="centerCrop"
        android:src="@drawable/rass"
        app:shapeAppearanceOverlay="@style/CircleImage"
        app:strokeColor="@color/orange_primary"
        app:strokeWidth="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="M. Farras Suryaputra"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#333333" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="NIM: 2457301078"
        android:textSize="16sp"
        android:textColor="#555555" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:paddingHorizontal="40dp"
        android:gravity="center"
        android:text="Mahasiswa Sistem Informasi yang sedang mengembangkan solusi digital untuk kemajuan desa."
        android:textSize="14sp"
        android:textColor="#666666" />

</LinearLayout>